# Copy to .env.e2e.local (gitignored) for local authenticated E2E runs.
# See docs/E2E_CI_HANDOFF.md for the phased Supabase isolation plan.

# Required for all E2E runs (perimeter + authenticated)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Authenticated tests only — disposable least-privilege user in the E2E project
E2E_EMAIL=
E2E_PASSWORD=

# Optional overrides
# E2E_PORT=3002
# PLAYWRIGHT_BASE_URL=http://localhost:3002
# E2E_TEST_MODE=authenticated

# Fail-closed allowlist lives in e2e/lib/supabase-project-guard.ts:
# E2E_ALLOWED_SUPABASE_PROJECT_REF — intentionally empty until Task 2 creates the E2E project.
